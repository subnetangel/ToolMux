{
  "mcpServers": {
    "toolmux": {
      "command": "uvx",
      "args": ["toolmux", "--config", "/Users/user/toolmux/mcp.json"],
      "timeout": 180000,
      "description": "ToolMux MCP server aggregator - exposes meta-tools for efficient access to all backend servers",
      "env": {
        "TOOLMUX_CONFIG": "/Users/user/toolmux/mcp.json",
        "TOOLMUX_LOG_LEVEL": "INFO"
      }
    }
  }
}